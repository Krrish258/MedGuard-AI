      "Furosemide": "Theoretical. Generally tolerated.",
      "Celecoxib": "Contains sulfonamide group. Avoid."
    },
    "safe_alternatives": ["Nitrofurantoin", "Fosfomycin", "Ciprofloxacin"]
  },
  "Aspirin": {
    "severity": "MAJOR",
    "avoid_classes": ["NSAIDs", "Salicylates", "COX-1 inhibitors"],
