    "safe_alternatives": ["Azithromycin", "Doxycycline", "Vancomycin", "Clindamycin"]
  },
  "Macrolides": {
    "severity": "MODERATE",
    "avoid_classes": ["Macrolides"],
    "avoid_drugs": ["Azithromycin", "Clarithromycin", "Erythromycin"],
