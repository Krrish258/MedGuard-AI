# MedGuard-AI Environment Configuration
# Copy this file to .env and fill in your actual values.

# HuggingFace Token (Optional: Required to bypass rate limits when downloading PubMedBERT)
HF_TOKEN=hf_your_token_here

# Kaggle API Credentials (Required to download the dataset during setup)
# Alternatively, these can be stored in ~/.kaggle/kaggle.json
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Generative LLM Integrations ──
# Required for the conversational Doctor output and semantic symptom processing
GEMINI_API_KEY=your_gemini_api_key_here
